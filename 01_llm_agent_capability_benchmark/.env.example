# 复制此文件为 .env 并填入你的 API key

# ============================================================
# 支持的模型及环境变量
# ============================================================

# 1. OpenAI GPT 系列
OPENAI_API_KEY=your_openai_api_key_here

# 2. Kimi (Moonshot) K2.5
# 中国版: https://api.moonshot.cn/v1
# 国际版: https://api.moonshot.ai/v1
KIMI_API_KEY=your_kimi_api_key_here
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# 3. MiniMax M2.7
# 国际版: https://api.minimax.io/v1
# 中国版: https://api.minimaxi.com/v1
MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# 4. DeepSeek V3.2
# 使用模型名: deepseek-chat (不是 deepseek-v3.2)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================================
# 其他配置（可选）
# ============================================================

# Anthropic Claude (可选)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 本地模型配置 (可选)
# LOCAL_MODEL_URL=http://localhost:8000/v1
